# API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
WEB_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=inboxos_session
SESSION_COOKIE_SECURE=false
SESSION_DB_PATH=~/.cache/inboxos/auth_sessions.sqlite3
SESSION_TTL_SECONDS=2592000
OAUTH_STATE_TTL_SECONDS=900
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. Defaults to localhost locally and uses RAILWAY_PUBLIC_DOMAIN on Railway.
GOOGLE_REDIRECT_URI=
GMAIL_CACHE_DB_PATH=~/.cache/inboxos/gmail_mailbox_cache.sqlite3

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SESSION_COOKIE_NAME=inboxos_session
